# ==============================================================================
#  Tiny S3 — Environment Configuration Template
#
#  Copy this file to .env and fill in your values.
#    cp .env.template .env
#
#  Rules:
#    - Lines starting with # are comments and are ignored
#    - Spacing around = is flexible: KEY=value and KEY = value both work
#    - Values are read as plain strings; no quoting is needed or supported
#    - Boolean values accept: true / false / 1 / 0 / yes / no
# ==============================================================================


# ------------------------------------------------------------------------------
# DEBUG MODE
#
# When true, every request (method, URI, headers, signature steps) is appended
# to the log file defined by LOG_FILE below.
#
# Set to false in production — the log file can grow very quickly under load
# and may expose sensitive data such as Authorization headers.
#
# Default: false
# ------------------------------------------------------------------------------
DEBUG = false


# ------------------------------------------------------------------------------
# CREDENTIALS
#
# These behave like AWS Access Key ID and Secret Access Key.
# All clients must sign their requests with the matching keys.
#
# ACCESS_KEY  — sent by the client in the Authorization header (not secret)
# SECRET_KEY  — used server-side to verify the HMAC-SHA256 signature (keep private)
#
# Use long random strings; there are no length restrictions.
# Example generation (Linux/macOS):
#   openssl rand -hex 20   → 40-character hex string
# ------------------------------------------------------------------------------
ACCESS_KEY = your-access-key-here
SECRET_KEY = your-secret-key-here


# ------------------------------------------------------------------------------
# AWS REGION
#
# The region name included in the Signature V4 credential scope.
# This must match whatever region string your S3 client sends.
#
# Most self-hosted clients (rclone, boto3, MinIO SDK) default to "us-east-1"
# when no region is explicitly configured. Change this only if your client is
# configured to use a different region string.
#
# Default: us-east-1
# ------------------------------------------------------------------------------
REGION = us-east-1


# ------------------------------------------------------------------------------
# STORAGE ROOT
#
# Directory where buckets and objects are stored on the local filesystem.
# Each bucket becomes a subdirectory; object keys map directly to file paths.
#
#   Example layout for STORAGE_ROOT = ./data :
#     ./data/
#     └── my-bucket/
#         ├── photo.jpg
#         └── backups/
#             └── db.sql.gz
#
# Paths are resolved relative to the directory containing index.php.
# An absolute path also works (e.g. /mnt/storage).
#
# The directory is created automatically when the first bucket is made,
# but the parent must already exist and be writable by the web server.
#
# Default: ./data
# ------------------------------------------------------------------------------
STORAGE_ROOT = ./data


# ------------------------------------------------------------------------------
# LOG FILE
#
# Path to the append-only activity log. Only written when DEBUG = true.
# Resolved relative to the directory containing index.php.
#
# Ensure the web server user has write permission to this file (or its parent
# directory, so the file can be created on first write).
#
# Default: activities.log
# ------------------------------------------------------------------------------
LOG_FILE = activities.log
