{
    "name": "franciscoteixeira/tiny-s3",
    "description": "A minimal AWS S3-compatible storage server written in pure PHP",
    "license": "MIT",
    "authors": [
        {
            "name": "Francisco Ernesto Teixeira"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "guzzlehttp/guzzle": "^7"
    },
    "autoload-dev": {
        "psr-4": {
            "TinyS3\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "@php -S localhost:8080 index.php",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration"
    },
    "config": {
        "process-timeout": 0
    }
}
